{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"types": ["vitest/globals"],
		"baseUrl": ".",
		"paths": {
			"@brrr/*": ["./src/*"]
		}
	},
	"include": ["./src/**/*.ts"]
}
